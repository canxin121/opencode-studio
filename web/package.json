{
  "name": "opencode-studio-web",
  "private": true,
  "version": "0.1.10",
  "type": "module",
  "scripts": {
    "dev": "bun run vite",
    "typecheck": "bun ./node_modules/vue-tsc/bin/vue-tsc.js -b",
    "build": "bun run check:imports && bun run typecheck && bun run vite build",
    "build:rust-debug": "bun run check:imports && bun run typecheck && bun run vite build --mode rust-debug",
    "check:imports": "bun ./scripts/check-import-rules.mjs",
    "fmt": "bun ./node_modules/prettier/bin/prettier.cjs -w .",
    "fmt:check": "bun ./node_modules/prettier/bin/prettier.cjs -c .",
    "test": "bun test",
    "preview": "bun run vite preview",
    "vite": "bun ./node_modules/vite/bin/vite.js"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.1.1",
    "@guolao/vue-monaco-editor": "^1.6.0",
    "@remixicon/vue": "^4.7.0",
    "@vueuse/core": "^14.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.32",
    "markdown-it": "^14.1.0",
    "markdown-it-texmath": "^1.0.0",
    "mermaid": "^11.12.2",
    "monaco-editor": "^0.55.1",
    "pinia": "^3.0.0",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^3.3.1",
    "vue": "^3.5.24",
    "vue-i18n": "^11",
    "vue-router": "^5.0.0",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.0.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.9.0",
    "postcss": "^8.5.6",
    "prettier": "^3.2.5",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.9.3",
    "esbuild": "^0.27.0",
    "vite": "^8.0.0",
    "vue-tsc": "^3.1.4"
  }
}
